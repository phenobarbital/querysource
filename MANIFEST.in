
include LICENSE
include CHANGES.rst
include CONTRIBUTING.md
include INSTALL
include README.md
include pyproject.toml
include setup.py
include Makefile
global-include *.typed
# Whitelist: only include QS package
graft querysource
graft tests
# Global excludes
global-exclude *.pyc
global-exclude __pycache__
global-exclude *.so
global-exclude *.o
global-exclude .git*
global-exclude .DS_Store
global-exclude .venv
prune docs
prune samples
prune examples
prune settings
prune plugins/*
recursive-exclude */__pycache__
prune */__pycache__
